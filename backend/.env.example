# ───────────────────────────────────────────────
# Backend configuration — copy to ".env" and adjust.
# NEVER commit the real .env (it is gitignored).
# ───────────────────────────────────────────────

# Server
PORT=4000
# Allowed CORS origin for the frontend (use the frontend URL in production)
CORS_ORIGIN=http://localhost:5173

# ── Database ──
# DB_DRIVER = "pglite" (default; embedded PostgreSQL, no server needed — great for dev)
#           = "pg"     (use a real PostgreSQL server via DATABASE_URL — use in production)
DB_DRIVER=pglite
# Folder where PGlite stores data (only used when DB_DRIVER=pglite)
PGLITE_DIR=./pgdata
# Connection string (only used when DB_DRIVER=pg)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/bengkel_las
# Set to "true" if your managed PostgreSQL requires SSL
DATABASE_SSL=false

# Auto-seed sample catalog on first run when DB is empty (true/false)
AUTO_SEED=true

# ── Auth ──
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_EXPIRES=12h
# Default admin account created by the seeder
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Chatbot (provider-agnostic) ──
# CHATBOT_PROVIDER = echo | openai | anthropic | gemini
# "echo" is a rule-based assistant that needs NO API key (default).
CHATBOT_PROVIDER=echo
# Your API key — kept server-side only, never exposed to the frontend.
CHATBOT_API_KEY=
# Optional overrides:
CHATBOT_MODEL=
CHATBOT_BASE_URL=

# Used by the seeder for the business WhatsApp number
SEED_WHATSAPP=628122827353
