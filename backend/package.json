{
  "name": "bengkel-las-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API untuk Bengkel Las Wijaya Konstruksi (Express + PostgreSQL)",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "db:reset": "node src/db/migrate.js --reset && node src/db/seed.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1"
  }
}
